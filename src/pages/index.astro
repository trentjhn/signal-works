---
import Layout from '@layouts/Layout.astro';
import Nav from '@components/Nav.astro';
import Hero from '@components/Hero.astro';
import Problem from '@components/Problem.astro';
import ProcessStep from '@components/ProcessStep.astro';
import About from '@components/About.astro';
import CTA from '@components/CTA.astro';
import Footer from '@components/Footer.astro';
import '../styles/global.css';

// Process is two faces, not three. The old "We Build" + "Hand Off" split was
// template filler for a two-person firm selling a single audit. The audit is
// what's being sold; what happens after is one story, not two.
const processSteps = [
  {
    numeral: 'I' as const,
    stepWord: 'One' as const,
    title: 'The Audit',
    body:
      "We sit down with you and go through your day-to-day: what tools you use, where time gets lost, what your team does that a system could handle instead. You leave with a written roadmap and a ranked list of what's worth building, scored by effort and impact. No vague findings.",
  },
  {
    numeral: 'II' as const,
    stepWord: 'Two' as const,
    title: 'After the Audit',
    body:
      "If you decide to move forward, we build the automations the audit surfaced. We connect your tools, configure the logic, and test against real scenarios. You get working automations with documentation and a walkthrough video, so your team knows exactly what was built and how to use it. Stay on with us for maintenance and new builds as your needs change, or take it from here. Either way, you keep everything.",
  },
];
---

<Layout>
  <Nav />
  <main>
    <Hero />
    <Problem />
    <ProcessStep stepNumber={1} numeral={processSteps[0].numeral} stepWord={processSteps[0].stepWord} title={processSteps[0].title} body={processSteps[0].body} background="bg" />
    <ProcessStep stepNumber={2} numeral={processSteps[1].numeral} stepWord={processSteps[1].stepWord} title={processSteps[1].title} body={processSteps[1].body} background="surface" />
    <About />
    <CTA />
  </main>
  <Footer />
</Layout>
