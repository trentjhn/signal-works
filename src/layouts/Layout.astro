---
// Layout.astro. Base layout shell.
// All pages inherit from this. Do not add page-specific content here.
import Analytics from '@vercel/analytics/astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'SignalWorks. Automation that actually gets built.',
  description = 'AI automation consulting for small businesses and agencies. We map your workflows, build what is worth building, and hand it off clean.',
  ogImage = '/og-image.png',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const siteOrigin = Astro.site?.origin ?? 'https://signalworks.live';

// Structured data graph. Cross-references via @id let crawlers and answer
// engines connect Organization, WebSite, ProfessionalService, and the two
// founder Person entities into one coherent entity profile. Pricing and
// timelines are intentionally omitted: the offer is in flux and the site
// does not publish numbers.
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': `${siteOrigin}/#organization`,
      name: 'SignalWorks',
      url: siteOrigin,
      logo: `${siteOrigin}/og-image.png`,
      image: `${siteOrigin}/og-image.png`,
      description:
        'Two-person AI automation consultancy. We map workflows, build the automations worth building, and hand them off with documentation.',
      slogan: 'Automation that actually gets built.',
      email: 'hello@signalworks.live',
      areaServed: [
        { '@type': 'City', name: 'Los Angeles' },
        { '@type': 'City', name: 'San Francisco' },
        { '@type': 'Country', name: 'United States' },
      ],
      founder: [
        { '@id': `${siteOrigin}/#trenton-johnson` },
        { '@id': `${siteOrigin}/#jahleel-heath` },
      ],
      contactPoint: {
        '@type': 'ContactPoint',
        contactType: 'sales',
        email: 'hello@signalworks.live',
        url: 'https://calendly.com/hello-signalworks',
        availableLanguage: ['English'],
      },
    },
    {
      '@type': 'WebSite',
      '@id': `${siteOrigin}/#website`,
      url: siteOrigin,
      name: 'SignalWorks',
      description,
      inLanguage: 'en-US',
      publisher: { '@id': `${siteOrigin}/#organization` },
    },
    {
      '@type': 'ProfessionalService',
      '@id': `${siteOrigin}/#service`,
      name: 'SignalWorks AI Automation Consulting',
      url: siteOrigin,
      provider: { '@id': `${siteOrigin}/#organization` },
      serviceType: [
        'AI automation consulting',
        'Workflow automation',
        'Agent engine optimization',
      ],
      areaServed: [
        { '@type': 'City', name: 'Los Angeles' },
        { '@type': 'City', name: 'San Francisco' },
      ],
      audience: {
        '@type': 'BusinessAudience',
        audienceType: 'Small business owners and marketing agency principals',
      },
      hasOfferCatalog: {
        '@type': 'OfferCatalog',
        name: 'SignalWorks Engagements',
        itemListElement: [
          {
            '@type': 'OfferCatalog',
            name: 'The Audit',
            description:
              'A working session that produces a written roadmap and a ranked list of automations worth building, scored by effort and impact.',
          },
          {
            '@type': 'OfferCatalog',
            name: 'After the Audit',
            description:
              'Implementation of the prioritized automations, handoff with documentation and a walkthrough video, optional ongoing maintenance.',
          },
        ],
      },
    },
    {
      '@type': 'Person',
      '@id': `${siteOrigin}/#trenton-johnson`,
      name: 'Trenton Johnson',
      jobTitle: 'Co-founder',
      worksFor: { '@id': `${siteOrigin}/#organization` },
      alumniOf: [
        { '@type': 'CollegeOrUniversity', name: 'Yale University' },
        { '@type': 'Organization', name: 'PayPal' },
      ],
      description:
        'Former Product Manager at PayPal. Yale Computer Science. Builds AI systems that run in production.',
    },
    {
      '@type': 'Person',
      '@id': `${siteOrigin}/#jahleel-heath`,
      name: 'Jahleel Heath',
      jobTitle: 'Co-founder',
      worksFor: { '@id': `${siteOrigin}/#organization` },
      description:
        'Los Angeles based entrepreneur and product builder. Years of AI implementation and application development.',
    },
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#FAFAF8" />

    <link rel="canonical" href={canonicalURL} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="SignalWorks" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- JSON-LD structured data. One @graph with cross-referenced @ids so
         Organization, WebSite, ProfessionalService, and the two founder
         Person nodes connect into a single entity profile for Google,
         Bing, and AI answer engines. -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- Google Fonts preconnect for Plus Jakarta Sans and Instrument Serif.  -->
    <!-- Cabinet Grotesk is self-hosted from /fonts/ so no fontshare          -->
    <!-- preconnect is needed.                                                -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Cabinet Grotesk 700 is discovered via the inlined @font-face rule   -->
    <!-- and fetched from the same Vercel edge as the HTML. We used to       -->
    <!-- preload it, but with the font self-hosted same-origin the preload   -->
    <!-- was elevating it to "critical" priority, which made Chrome delay    -->
    <!-- first paint by a few hundred ms in a bid to avoid FOUT even under   -->
    <!-- font-display: swap. Removing the preload lets the fallback paint    -->
    <!-- immediately and the real font swap in when it arrives.              -->

    <!-- Google Fonts CSS loaded non-render-blocking via the media=print     -->
    <!-- onload swap. Browsers treat a non-matching media query as non-      -->
    <!-- blocking; onload flips it back to all once loaded. font-display:    -->
    <!-- swap in the URL renders text with the fallback immediately and      -->
    <!-- swaps in Jakarta / Instrument Serif as soon as they arrive.         -->
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600&family=Instrument+Serif:ital@0;1&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600&family=Instrument+Serif:ital@0;1&display=swap"
      />
    </noscript>

    <title>{title}</title>
  </head>
  <body>
    <a href="#hero" class="skip-link">Skip to content</a>
    <div class="page-grain" aria-hidden="true"></div>
    <slot />

    <!-- IntersectionObserver reveal: fades content in as it enters view.
         Also observes .stroke-reveal for the clip-path numeral wipe.

         Gated on document.fonts.ready so the hero headline cascade only
         plays once Cabinet Grotesk is actually loaded. On a cold cache
         the fallback sans-serif has narrower metrics than Cabinet Grotesk
         800, and running the reveal during that window meant the headline
         animated in at the wrong size and then snapped to the real font.
         document.fonts.ready also has a ~3s safety timeout in case the
         font never loads, so users aren't left staring at an empty hero. -->
    <script>
      const startReveal = () => {
        const revealElements = document.querySelectorAll(
          '.reveal, .reveal-stagger, .stroke-reveal, .reveal-aside'
        );
        if (revealElements.length === 0) return;

        document.querySelectorAll('[data-stagger-group]').forEach((group) => {
          const children = group.querySelectorAll('.reveal-stagger');
          children.forEach((child, index) => {
            (child as HTMLElement).style.setProperty('--stagger-delay', `${index * 80}ms`);
          });
        });

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                observer.unobserve(entry.target);
              }
            });
          },
          {
            threshold: 0.1,
            rootMargin: '0px 0px -40px 0px',
          }
        );

        revealElements.forEach((el) => observer.observe(el));
      };

      const init = () => {
        if (document.fonts && document.fonts.ready) {
          let started = false;
          const go = () => {
            if (started) return;
            started = true;
            startReveal();
          };
          document.fonts.ready.then(go);
          // Safety: if the font CDN hangs, start the reveal anyway after 2s
          // so users never see a permanently-hidden hero.
          window.setTimeout(go, 2000);
        } else {
          startReveal();
        }
      };

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
      } else {
        init();
      }
    </script>

    <Analytics />
  </body>
</html>
