---
// Process.astro
// How it works. Three steps. Editorial vertical rows with large serif numerals.
// Copy verbatim from PROJECT.md. Do not paraphrase.

const steps = [
  {
    n: 'I',
    title: 'The Audit',
    body:
      "We sit down with you and go through your actual day-to-day — what tools you use, where time gets lost, what your team does that a system could handle instead. Most clients are surprised how quickly the high-impact opportunities surface. You leave with a written roadmap and a ranked list of what's worth building. No vague findings.",
  },
  {
    n: 'II',
    title: 'We Build',
    body:
      "If you want to move forward, we build the automations that came out of the audit. We connect your tools, configure the logic, and test against real scenarios. You don't need to be technical. You just need to show us your workflows. We hand off working automations, not mockups.",
  },
  {
    n: 'III',
    title: 'Hand Off and Run',
    body:
      "We hand off with documentation and a walkthrough video, so your team knows exactly what was built and how to use it. If you want us to stay on for ongoing maintenance and new automations as your needs change, we can. If you want to take it from here, you have everything you need.",
  },
] as const;
---

<section
  id="process"
  class="grain section-padding bg-background"
  aria-label="How it works"
>
  <div class="container">

    <!-- Section header — asymmetric, headline left, breathing space right -->
    <div class="grid grid-cols-1 lg:grid-cols-[60fr_40fr] gap-8 lg:gap-16 mb-16 lg:mb-20 items-end">
      <div>
        <p class="eyebrow mb-5 reveal">How It Works</p>
        <h2 class="font-cabinet font-bold text-headline text-text-primary reveal">
          Three steps.
          <br />
          First one tells you everything you need to know.
        </h2>
      </div>
    </div>

    <!-- Stepped rows — 15/85 asymmetry: serif numeral rail, content body -->
    <div class="flex flex-col" data-stagger-group>
      {steps.map((step, i) => (
        <div
          class={`reveal-stagger grid grid-cols-[48px_1fr] lg:grid-cols-[120px_1fr] gap-6 lg:gap-12 py-10 lg:py-14 border-t border-border ${
            i === steps.length - 1 ? 'border-b border-border' : ''
          }`}
        >
          <!-- Serif numeral — Instrument Serif italic for editorial contrast -->
          <div class="pt-1 lg:pt-2">
            <span
              class="editorial block text-[40px] lg:text-[64px] leading-none text-accent"
              aria-hidden="true"
            >
              {step.n}
            </span>
          </div>

          <!-- Content -->
          <div class="max-w-[62ch]">
            <h3 class="font-cabinet font-semibold text-subhead text-text-primary mb-4">
              Step {i + 1}: {step.title}
            </h3>
            <p class="font-jakarta text-body text-text-secondary">
              {step.body}
            </p>
          </div>
        </div>
      ))}
    </div>

    <!-- Closing line — editorial accent, right-aligned on desktop for asymmetry -->
    <p
      class="editorial text-editorial text-text-primary max-w-[52ch] mt-16 lg:mt-20 lg:ml-[120px] reveal"
      style="letter-spacing: 0.005em;"
    >
      Most clients have their first automation running not long after the audit.
    </p>

  </div>
</section>
