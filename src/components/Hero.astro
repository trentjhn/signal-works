---
// Hero.astro
// All copy from PROJECT.md — do not edit copy here without updating PROJECT.md.
// Layout: single strong left-aligned editorial block. Whitespace on the right
// is intentional — the headline carries the section. No stat panel, no images.
// PayPal stats live in About, not here.
const CALENDLY_URL = 'https://calendly.com/signalworks'; // TODO: replace with real Calendly link
---

<section
  id="hero"
  class="grain section-padding bg-background min-h-[90vh] flex items-center"
  aria-label="Hero"
>
  <div class="container w-full">

    <div class="max-w-[880px]">

      <h1
        class="font-cabinet font-extrabold text-display text-text-primary mb-10 reveal-stagger"
        style="--stagger-delay: 0ms;"
      >
        We build the workflows
        <br class="hidden md:block" />
        you wish your AI&nbsp;tools
        <br class="hidden md:block" />
        did on their&nbsp;own.
      </h1>

      <p
        class="font-jakarta text-body-lg text-text-secondary max-w-[58ch] mb-10 reveal-stagger"
        style="--stagger-delay: 80ms"
      >
        We sit down with you, map your actual workflows,
        and hand you a prioritized plan for what's worth automating —
        whether you work with us or not.
      </p>

      <div class="mb-14 reveal-stagger" style="--stagger-delay: 160ms">
        <a
          href={CALENDLY_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary"
        >
          Book a Workflow Audit
        </a>
      </div>

      <!-- Thin rule + editorial accent line — quiet punctuation, no stat -->
      <!-- panel. This replaces the old "processed over 100M transactions" -->
      <!-- line which was PayPal borrowed credibility in the wrong place.  -->
      <div class="reveal-stagger" style="--stagger-delay: 240ms">
        <hr class="border-0 border-t border-border max-w-[120px] mb-6" />
        <p class="editorial text-editorial text-text-secondary max-w-[44ch]">
          We know the difference between what demos well
          <br class="hidden sm:block" />
          and what actually works.
        </p>
      </div>

    </div>
  </div>
</section>
