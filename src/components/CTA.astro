---
// CTA.astro
// Final CTA. One headline, one subtext, one button, one trust line.
// Copy verbatim from PROJECT.md. Resist filling space.
import { CALENDLY_URL, CONTACT_EMAIL } from '@config/links';
---

<section
  id="cta"
  class="section bg-background"
  aria-label="Book an intro call"
>
  <div class="container">

    <!-- Asymmetric: content block offset left, breathing right -->
    <div class="max-w-[880px]">

      <!-- Headline.section headline scale, Cabinet Grotesk 700 -->
      <h2
        class="font-cabinet font-bold text-headline text-text-primary max-w-[22ch] mb-8 reveal"
      >
        If you're losing ten hours a week to work that shouldn't require a human, this is what the audit is for.
      </h2>

      <!-- Subtext -->
      <p
        class="font-jakarta text-body-lg text-text-secondary max-w-[58ch] mb-10 reveal"
      >
        We start with a 30-minute intro call. If we both see a fit, the audit comes next.
        You get focused attention on your specific workflows,
        a written summary of what's worth automating, and a prioritized roadmap.
        If you decide not to move forward after that, you still have the roadmap.
        No follow-up pitch.
      </p>

      <!-- Primary CTA. Calendly stays the dominant action. The mailto -->
      <!-- below is a quiet alternate for visitors who prefer not to    -->
      <!-- self-book. PROJECT.md says one action, no secondary goal,    -->
      <!-- so the mailto is treated as a same-action variant of contact -->
      <!-- rather than a competing CTA: no second button, no styling    -->
      <!-- weight, just a sentence.                                     -->
      <div class="mb-10 reveal">
        <a
          href={CALENDLY_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary"
        >
          Book an Intro Call
        </a>
        <p class="font-jakarta text-body text-text-secondary mt-5">
          Or send us a note at{' '}
          <a
            href={`mailto:${CONTACT_EMAIL}`}
            class="text-text-primary underline underline-offset-4 decoration-1 hover:text-accent transition-colors duration-[150ms]"
          >
            {CONTACT_EMAIL}
          </a>.
        </p>
      </div>

      <!-- Thin rule separator.unified to 120px to match Hero + ProcessStep. -->
      <hr class="border-0 border-t border-border max-w-[120px] mb-8" />

      <!-- Trust signal.Instrument Serif italic. Commitment-first, not -->
      <!-- money-first, because pricing is in flux and a refund line      -->
      <!-- implies a number the site isn't stating.                       -->
      <p
        class="editorial text-editorial text-text-primary max-w-[52ch] reveal"
      >
        The audit has a clear deliverable. If we can't surface at least three concrete opportunities worth building, we tell you honestly. No pitch, no continued engagement.
      </p>

    </div>
  </div>
</section>
