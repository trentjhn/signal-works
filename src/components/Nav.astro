---
// Nav.astro
// Sticky navigation. Adds border-bottom on scroll (no blur.see DESIGN.md).
import { CALENDLY_URL } from '@config/links';
---

<header
  id="nav"
  class="sticky top-0 z-50 bg-background transition-colors duration-200"
>
  <div class="container">
    <nav class="flex items-center justify-between h-[60px] md:h-[68px]">

      <!-- Logo.brand weight. 24px font-extrabold reads as presence     -->
      <!-- without dominating the 68px rail.                               -->
      <a
        href="/"
        class="font-cabinet font-extrabold text-[22px] md:text-[24px] text-text-primary tracking-[-0.01em] hover:text-accent transition-colors duration-[150ms]"
        aria-label="SignalWorks home"
      >
        SignalWorks.
      </a>

      <!-- Right cluster: nav links + CTA grouped together. -->
      <div class="hidden md:flex items-center gap-10">
        <ul class="flex items-center gap-8 list-none">
          {([
            { label: 'Process', href: '#process-1' },
            { label: 'About', href: '#about' },
          ] as const).map((item) => (
            <li>
              <a
                href={item.href}
                class="font-jakarta font-semibold text-label uppercase tracking-[0.08em] text-text-secondary hover:text-text-primary transition-colors duration-[150ms]"
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
        <a
          href={CALENDLY_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary-sm"
        >
          Book an Intro Call
        </a>
      </div>

      <!-- Mobile hamburger (toggle script below). -->
      <button
        id="mobile-menu-toggle"
        type="button"
        class="md:hidden flex flex-col gap-1.5 p-2 -mr-2 focus-visible:outline focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-[3px] rounded-btn"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <span class="block w-6 h-0.5 bg-text-primary transition-all duration-200" id="bar-1"></span>
        <span class="block w-6 h-0.5 bg-text-primary transition-all duration-200" id="bar-2"></span>
        <span class="block w-6 h-0.5 bg-text-primary transition-all duration-200" id="bar-3"></span>
      </button>
    </nav>
  </div>
</header>

<!-- Mobile menu overlay. `inert` keeps focus out when closed. -->
<div
  id="mobile-menu"
  class="fixed inset-0 bg-background z-40 flex flex-col items-center justify-center gap-8 opacity-0 pointer-events-none transition-opacity duration-200"
  aria-hidden="true"
  inert
>
  <ul class="flex flex-col items-center gap-6 list-none">
    {([
      { label: 'Process', href: '#process-1' },
      { label: 'About', href: '#about' },
    ] as const).map((item) => (
      <li>
        <a
          href={item.href}
          class="font-cabinet font-bold text-[clamp(32px,6vw,48px)] text-text-primary hover:text-accent transition-colors duration-[150ms] mobile-nav-link"
        >
          {item.label}
        </a>
      </li>
    ))}
  </ul>
  <a
    href={CALENDLY_URL}
    target="_blank"
    rel="noopener noreferrer"
    class="btn-primary mobile-nav-link"
  >
    Book an Intro Call
  </a>
</div>

<script>
  const nav = document.getElementById('nav');
  const mobileMenu = document.getElementById('mobile-menu');
  const toggle = document.getElementById('mobile-menu-toggle');
  const bar1 = document.getElementById('bar-1');
  const bar2 = document.getElementById('bar-2');
  const bar3 = document.getElementById('bar-3');
  const mobileLinks = document.querySelectorAll('.mobile-nav-link');
  let menuOpen = false;

  // Scroll border. rAF-throttled so the class toggle fires at most once per frame.
  let scrollTicking = false;
  window.addEventListener('scroll', () => {
    if (scrollTicking) return;
    scrollTicking = true;
    requestAnimationFrame(() => {
      if (window.scrollY > 80) {
        nav?.classList.add('border-b', 'border-border');
      } else {
        nav?.classList.remove('border-b', 'border-border');
      }
      scrollTicking = false;
    });
  }, { passive: true });

  // Mobile toggle
  function toggleMenu(open: boolean) {
    menuOpen = open;
    if (!mobileMenu || !toggle) return;
    mobileMenu.style.opacity = open ? '1' : '0';
    mobileMenu.style.pointerEvents = open ? 'auto' : 'none';
    mobileMenu.setAttribute('aria-hidden', String(!open));
    if (open) {
      mobileMenu.removeAttribute('inert');
    } else {
      mobileMenu.setAttribute('inert', '');
    }
    toggle.setAttribute('aria-expanded', String(open));
    toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
    document.body.style.overflow = open ? 'hidden' : '';

    // Animate bars
    if (bar1 && bar2 && bar3) {
      bar1.style.transform = open ? 'translateY(8px) rotate(45deg)' : '';
      bar2.style.opacity = open ? '0' : '1';
      bar3.style.transform = open ? 'translateY(-8px) rotate(-45deg)' : '';
    }

    // Return focus to the toggle when closing, so keyboard users land somewhere
    // predictable instead of being dropped at document start.
    if (!open) {
      (toggle as HTMLButtonElement).focus();
    }
  }

  toggle?.addEventListener('click', () => toggleMenu(!menuOpen));
  mobileLinks.forEach(link => link.addEventListener('click', () => toggleMenu(false)));

  // Escape closes the mobile menu when open.
  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape' && menuOpen) {
      toggleMenu(false);
    }
  });
</script>
