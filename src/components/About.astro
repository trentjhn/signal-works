---
// About.astro
// Two founder bios in an editorial stacked layout.
// Both founders framed as builders. Role labels intentionally absent; the
// bios carry the distinction. Section headline leads on AI-native capability
// rather than headcount.

const founders = [
  {
    name: 'Trenton Johnson',
    location: null,
    body:
      "Former Product Manager at PayPal. Yale Computer Science. Left PayPal to build AI systems that run in production. That's still the bar: systems a business can depend on from day one, built for real use, real data, and real teams.",
  },
  {
    name: 'Jahleel Heath',
    location: null,
    body:
      "Los Angeles-based entrepreneur and product builder. Years of AI implementation and application development. I find where AI actually creates value inside a business, then build the systems that make it real.",
  },
] as const;
---

<section
  id="about"
  class="section bg-surface"
  aria-label="Who we are"
>
  <div class="container">

    {/* Section boundary. Process II and About share bg-surface, so a quiet
        full-container rule at the top of About prevents the two sections
        from reading as one continuous block. */}
    <hr class="border-0 border-t border-border mb-20 lg:mb-24 reveal" />

    <!-- Section header. Single column, left-aligned. -->
    <div class="mb-16 lg:mb-20 max-w-[920px]">
      <p class="eyebrow mb-5 reveal">Who We Are</p>
      <h2 class="font-cabinet font-bold text-headline text-text-primary reveal">
        We live inside the AI stack
        <br />
        so your team doesn't have to.
      </h2>
    </div>

    <!-- Founder bios.stacked editorial rows -->
    <div class="flex flex-col">
      {founders.map((f, i) => (
        <article
          class={`reveal grid grid-cols-1 lg:grid-cols-[280px_1fr] gap-8 lg:gap-16 py-12 lg:py-16 border-t border-border ${
            i === founders.length - 1 ? 'border-b border-border' : ''
          }`}
        >
          <!-- Left rail: name only. Role labels dropped; bios speak for themselves. -->
          <header class="flex flex-col gap-3">
            <h3 class="font-cabinet font-bold text-subhead text-text-primary">
              {f.name}
            </h3>
            {f.location && (
              <p class="font-jakarta text-label-sm uppercase tracking-[0.10em] text-text-secondary">
                {f.location}
              </p>
            )}
          </header>

          <!-- Right: bio prose -->
          <div class="max-w-[62ch]">
            <p class="font-jakarta text-body text-text-secondary">
              {f.body}
            </p>
          </div>
        </article>
      ))}
    </div>

  </div>
</section>
