---
// About.astro
// Two founder bios in an editorial stacked layout.
// Both founders framed as builders. Role labels intentionally absent; the
// bios carry the distinction. Section headline leads on AI-native capability
// rather than headcount.

import { Image } from 'astro:assets';
import trentImg from '../assets/team/trent.jpg';
import jahleelImg from '../assets/team/jahleel.jpg';

const founders = [
  {
    name: 'Trenton Johnson',
    location: null,
    photo: trentImg,
    body:
      "Former Product Manager at PayPal. Yale Computer Science. Left PayPal to build AI systems that run in production. That's still the bar: systems a business can depend on from day one, built for real use, real data, and real teams.",
  },
  {
    name: 'Jahleel Heath',
    location: null,
    photo: jahleelImg,
    body:
      "Built and led product strategy for an enterprise K-12 SaaS platform, from architecture to launch. Background in NIL marketing, brand activation, and nonprofit operations. Finds where AI creates real value inside a business, then builds the systems that make it land.",
  },
] as const;
---

<section
  id="about"
  class="section bg-surface"
  aria-label="Who we are"
>
  <div class="container">

    {/* Section boundary. Process II and About share bg-surface, so a quiet
        full-container rule at the top of About prevents the two sections
        from reading as one continuous block. */}
    <hr class="border-0 border-t border-border mb-20 lg:mb-24 reveal" />

    <!-- Section header. Single column, left-aligned.
         The old subhead under the headline named "agent engine optimization"
         as a focus, which structurally read as a value prop and overweighted
         a single specialty. AEO is still a live focus for the firm, but it
         now lives as a pulled-out observation at the bottom of this section
         (see the aside below) so the header can carry the broader
         who-we-are statement without competing. -->
    <div class="mb-16 lg:mb-20 max-w-[920px]">
      <p class="eyebrow mb-5 reveal">Who We Are</p>
      <h2 class="font-cabinet font-bold text-headline text-text-primary reveal">
        We live inside the AI stack
        <br />
        so your team doesn't have to.
      </h2>
    </div>

    <!-- Founder bios.stacked editorial rows -->
    <div class="flex flex-col">
      {founders.map((f, i) => (
        <article
          class={`reveal grid grid-cols-1 lg:grid-cols-[180px_1fr] gap-8 lg:gap-12 py-12 lg:py-16 border-t border-border ${
            i === founders.length - 1 ? 'border-b border-border' : ''
          }`}
        >
          <!-- Left rail: portrait + name. Photo at 4:5 (editorial portrait
               ratio) so wardrobe and shoulders read, not just the face.
               Subtle 8px corner radius matches the soft-sharp system
               (DESIGN.md): rounded for warmth, never pillish or razor-edged.
               No drop shadow, no border. Rail sized to the photo (180px) so
               the name centers naturally below the image on desktop. On
               mobile the rail expands and photo + name align left to match
               the editorial alignment of the bio prose. Role labels dropped;
               bios speak for themselves. -->
          <header class="flex flex-col gap-4 items-start lg:items-center">
            <Image
              src={f.photo}
              alt={f.name}
              width={400}
              quality={85}
              class="w-full max-w-[160px] lg:max-w-[180px] aspect-[4/5] object-cover object-[center_top] rounded-lg"
              loading="lazy"
            />
            <h3 class="font-cabinet font-bold text-subhead text-text-primary lg:text-center">
              {f.name}
            </h3>
            {f.location && (
              <p class="font-jakarta text-label-sm uppercase tracking-[0.10em] text-text-secondary lg:text-center">
                {f.location}
              </p>
            )}
          </header>

          <!-- Right: bio prose -->
          <div class="max-w-[62ch]">
            <p class="font-jakarta text-body text-text-secondary">
              {f.body}
            </p>
          </div>
        </article>
      ))}
    </div>

    {/* Pulled-out observation from the founders. Uses the same family
        and size as the bio prose above (Plus Jakarta sans at body-lg)
        so it reads as one more paragraph in their voice, set apart
        only by a thin left bar + left padding. Deliberately NOT in
        Instrument Serif italic.the italic serif already has one home
        on the page (the hero's sign-off), and trying to reuse it here
        forced every previous iteration into an awkward Goldilocks
        search on size and weight. Treating this as a pull-out aside
        in the bios' own voice frees it from that trap. Left bar is a
        visual vocabulary the site doesn't use anywhere else, so it
        reads as distinct without needing a label or rule. AEO stays
        out of the public copy on purpose: naming the phenomenon
        signals the territory without branding the firm as a
        monolithic AEO shop. */}
    <aside class="reveal-aside pt-12 lg:pt-16" aria-label="Closing note">
      <p class="font-jakarta text-body-lg text-text-secondary max-w-[54ch] pl-6">
        The search bar is moving inside AI assistants. Most businesses haven't noticed yet.
      </p>
    </aside>

  </div>
</section>
