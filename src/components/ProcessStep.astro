---
// ProcessStep.astro
// One face of the Process deck. Mounted from index.astro with step props.
// Copy verbatim from PROJECT.md. Do not rewrite.
//
// Layout: single content column. The step numeral is demoted to an inline
// mark at the start of the eyebrow row (was previously an oversized left-
// rail display glyph, cut because it read as Webflow-template decoration).

interface Props {
  stepNumber: 1 | 2;
  numeral: 'I' | 'II';
  stepWord: 'One' | 'Two';
  title: string;
  body: string;
  background: 'bg' | 'surface';
  closing?: string;
}

const { stepNumber, numeral, stepWord, title, body, background, closing } = Astro.props;
const bgClass = background === 'surface' ? 'bg-surface' : 'bg-background';
// Content-specific label so two sibling Process sections don't read as duplicates
// to assistive tech. Uses the step title rather than "step 1 of 2".
const sectionLabel = `Process, Step ${stepWord}: ${title}`;
---

<section
  id={`process-${stepNumber}`}
  class={`section ${bgClass}`}
  aria-label={sectionLabel}
>
  <div class="container">

    <div class="max-w-[720px]">

      <!-- Eyebrow row with inline serif numeral as a quiet mark. -->
      <div
        class="flex items-baseline gap-3 mb-6 reveal-stagger"
        style="--stagger-delay: 0ms"
      >
        <span
          class="editorial text-accent leading-none"
          style="font-size: 26px;"
          aria-hidden="true"
        >
          {numeral}
        </span>
        <span class="eyebrow">Step {stepWord} · How It Works</span>
      </div>

      <h2
        class="font-cabinet font-bold text-headline text-text-primary mb-8 reveal-stagger"
        style="--stagger-delay: 80ms"
      >
        {title}
      </h2>
      <p
        class="font-jakarta text-body-lg text-text-secondary reveal-stagger"
        style="--stagger-delay: 160ms"
      >
        {body}
      </p>

      {closing && (
        <div class="reveal-stagger" style="--stagger-delay: 240ms">
          <hr class="border-0 border-t border-border max-w-[120px] my-10" />
          <p class="editorial text-editorial text-text-primary max-w-[52ch]">
            {closing}
          </p>
        </div>
      )}

    </div>
  </div>
</section>
