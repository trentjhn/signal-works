---
// Problem.astro
// Cream background section. Names the pain the target audience already feels.
// Do not soften the copy.the directness is intentional and signals confidence.
//
// Icons: hand-rolled abstract geometric marks. NOT pictographic.
// Each callout uses a distinct silhouette so the set reads as varied, not as
// a matched feature grid.
//   1. Compile .three stacked horizontal rules (strata / report rows)
//   2. Crack   .broken horizontal line with a diagonal strike through the gap
//   3. Duplicate. Two offset rectangles (copy-paste metaphor)
//   4. Unclosed.nearly-full arc with a small gap at the origin (cycle that never closes)

const pains = [
  { icon: 'compile',  text: 'Client reporting that takes hours to compile' },
  { icon: 'crack',    text: 'Follow-up emails that fall through the cracks' },
  { icon: 'duplicate',text: 'Staff copy-pasting between tools every morning' },
  { icon: 'unclosed', text: 'Proposals built from scratch every time' },
] as const;
---

<section
  id="problem"
  class="section bg-surface"
  aria-label="The Problem"
>
  <div class="container">

    <!-- Two-column editorial: 55/45 split on desktop, stacked on mobile -->
    <div class="grid grid-cols-1 lg:grid-cols-[55fr_45fr] gap-12 lg:gap-14 items-start">

      <!-- Left: headline block -->
      <div>
        <p class="eyebrow mb-5 reveal">The Problem</p>
        <h2 class="font-cabinet font-bold text-headline text-text-primary mb-6 reveal">
          You're subscribed to the tools.
          <br />
          The manual work didn't stop.
        </h2>
        <p class="font-jakarta text-body-lg text-text-secondary max-w-reading-lg reveal">
          Most small businesses and agencies are paying employees to do things that could
          run automatically: moving data between apps, following up on leads, summarizing
          reports, updating CRMs. Not because the solutions don't exist. Because nobody on
          your team has the time or background to connect the pieces. The AI tools are there.
          The workflow is still broken.
        </p>
      </div>

      <!-- Right: pain point callouts.editorial rows, NOT a card grid -->
      <ul class="flex flex-col gap-0 list-none lg:pt-12" data-stagger-group>
        {pains.map((p, i) => (
          <li
            class={`reveal-stagger flex items-start gap-5 py-4 border-b border-border-subtle ${
              i === 0 ? 'border-t border-border-subtle' : ''
            }`}
          >
            <span
              class="flex-shrink-0 mt-[3px] text-text-secondary"
              aria-hidden="true"
            >
              {p.icon === 'compile' && (
                <svg viewBox="0 0 20 20" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round">
                  <path d="M3 6 h14" />
                  <path d="M3 10 h10" />
                  <path d="M3 14 h12" />
                </svg>
              )}
              {p.icon === 'crack' && (
                <svg viewBox="0 0 20 20" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round">
                  <path d="M3 10 h5" />
                  <path d="M12 10 h5" />
                  <path d="M9 6 L11 14" />
                </svg>
              )}
              {p.icon === 'duplicate' && (
                <svg viewBox="0 0 20 20" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linejoin="round">
                  <rect x="3" y="3" width="11" height="11" rx="1" />
                  <rect x="6" y="6" width="11" height="11" rx="1" />
                </svg>
              )}
              {p.icon === 'unclosed' && (
                <svg viewBox="0 0 20 20" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round">
                  <path d="M10 4 A6 6 0 1 1 6 5" />
                </svg>
              )}
            </span>
            <p class="font-jakarta text-body text-text-secondary leading-snug">{p.text}</p>
          </li>
        ))}
      </ul>

    </div>
  </div>
</section>
